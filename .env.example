DEBUG=false

LOGGING__LEVEL=info

# gRPC endpoints of backend services (in-cluster hostname:port).
AUTH_SERVICE_URL=placebrain-auth-service:50051
PLACES_SERVICE_URL=placebrain-places-service:50052
DEVICES_SERVICE_URL=placebrain-devices-service:50053
COLLECTOR_SERVICE_URL=placebrain-collector-service:50054

# Must match JWT__SECRET in the auth service — used to validate incoming tokens.
JWT_SECRET=replace-with-a-long-random-hex-string
